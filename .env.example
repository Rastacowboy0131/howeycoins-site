# $HOWEYCOINS fully automatic claim -> buyback -> airdrop runner
# Copy to .env locally. Never commit real private keys.

# Existing Helius RPC from the claim app can be reused as RPC_URL.
RPC_URL=

# Base58 secret key for the dev wallet. Do not paste this into chat or commit it.
PRIVATE_KEY=

HOWEYCOINS_MINT=G3Q6iQ4xMG3vH9SyKSkupvEeeKiRLvvmCqAQ9iyGpump
DEV_PUBLIC_KEY=Ehr92fYMp2DmzavJCCY4wfGnYLasucDPBnodqjL2agWz

# Per user: dev wallet is also ops wallet and airdrop sender wallet.
# These default to DEV_PUBLIC_KEY if left blank.
OPS_PUBLIC_KEY=
AIRDROP_PUBLIC_KEY=

# Exclude LP/pool token-owner wallets here once known.
# Comma or newline separated.
LP_POOL_WALLETS=
EXCLUDED_WALLETS=

# Fully auto live-spend gates. Both must be true or the script refuses to run.
ENABLE_REAL_TX=false
FULLY_AUTO=false

# Cadence and reserve.
# Claim + buyback runs every 60 seconds. Bought tokens queue up and airdrop every 5 minutes.
INTERVAL_MS=60000
AIRDROP_INTERVAL_MS=300000
MIN_CLAIM_SOL=0.01
MIN_BUYBACK_SOL=0.01
GAS_RESERVE_SOL=0.1
BUYBACK_SHARE=1
RESERVE_SHARE=0
OPS_SHARE=0
MAX_WALLET_SHARE=0.03
SLIPPAGE_BPS=500

# Helpful first live test: run once, then exit.
LOOP_ONCE=false

# Public receipt output consumed by the site when deployed/copied.
RECEIPT_DIR=data/runs
LATEST_RECEIPT_PATH=data/latest.json
STATE_PATH=data/howey-auto-state.json
